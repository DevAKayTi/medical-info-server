{
  "name": "medisource-server",
  "version": "1.0.0",
  "description": "MediSource Global — Enterprise Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "seed": "ts-node src/database/seeders/seed.ts",
    "seed:clean": "ts-node src/database/seeders/seed.ts --clean",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "mongoose": "^8.4.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "zod": "^3.23.8",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^2.2.0",
    "nodemailer": "^6.9.13",
    "bull": "^4.12.2",
    "ioredis": "^5.3.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.3.1",
    "cookie-parser": "^1.4.6",
    "slugify": "^1.6.6",
    "dotenv": "^16.4.5",
    "winston": "^3.13.0",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.15",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/compression": "^1.7.5",
    "@types/bull": "^4.10.0",
    "@types/cookie-parser": "^1.4.7",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2"
  }
}
